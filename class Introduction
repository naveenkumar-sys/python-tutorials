#2.wihtout constructor
class Student:
    #while we are creating the object , we pass the value to constructor
    def person(self,name,age):
        self.name=name
        self.age=age
    
    def change_name(self,name):
        self.name=name

#instance
s1=Student()
#creating object and passing the value to method 
s1.person("Arjun",34)
print(s1.name)
s1.change_name("Raj")
print(s1.name)