#2.wihtout constructor
class Student:
    #while we are creating the object , we pass the value to constructor
    def person(self,name,age):
        self.name=name
        self.age=age
    
    def change_name(self,name):
        self.name=name

#instance
s1=Student()
#creating object and passing the value to method 
s1.person("Arjun",34)
print(s1.name)
s1.change_name("Raj")
print(s1.name)

#Note: Every instance method must have self as its first parameter.


#Inheritance - child  use parent attribute or method  or children class are derived from parent class
class Car:
    def service(self):
        print("The service is should be same for all cars")

class Baleno(Car):
    def speed(self):
        print("This has decent engine , It provide high nm of torque and speed")


car1=Baleno()
car1.service()   # Inherited from Car
car1.speed()     # Defined in Baleno


